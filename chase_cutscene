<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
<title>PROXY_NODE://04 — TRANSMISSION</title>
<style>
  @import url("https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap");

  :root{
    --bg:            #030604;
    --green:         #33ff6e;
    --green-dim:     #0f6b2e;
    --green-bright:  #b9ffd6;
    --red:           #ff3b3b;
    --font-display:  "VT323", monospace;
    --font-body:     "Share Tech Mono", monospace;
  }
  *{ box-sizing:border-box; }
  html,body{
    margin:0; padding:0; min-height:100%;
    background:var(--bg); color:var(--green);
    font-family:var(--font-body);
    -webkit-tap-highlight-color:transparent;
  }

  #crt{ position:relative; min-height:100vh; width:100%; padding:20px 14px 34px; display:flex; flex-direction:column; align-items:center; }
  #crt::before{
    content:""; position:fixed; inset:0; pointer-events:none; z-index:50;
    background:repeating-linear-gradient(to bottom, rgba(0,0,0,0) 0px, rgba(0,0,0,0.18) 1px, rgba(0,0,0,0) 2px);
    mix-blend-mode:multiply;
  }
  #crt::after{
    content:""; position:fixed; inset:0; pointer-events:none; z-index:51;
    background:radial-gradient(ellipse at center, rgba(0,0,0,0) 55%, #000 100%);
    animation:flicker 6.5s infinite;
  }
  @keyframes flicker{ 0%,100%{opacity:.35;} 2%{opacity:.55;} 4%{opacity:.35;} 50%{opacity:.4;} 52%{opacity:.25;} }

  #noise-canvas{ position:fixed; inset:0; width:100%; height:100%; z-index:60; pointer-events:none; opacity:0; }

  .terminal{
    width:100%; max-width:460px;
    border:1px solid var(--green-dim);
    background:linear-gradient(180deg, rgba(20,40,26,0.25), rgba(0,0,0,0.15));
    box-shadow:0 0 18px rgba(51,255,110,0.08), inset 0 0 40px rgba(51,255,110,0.03);
  }
  .titlebar{
    display:flex; justify-content:space-between; align-items:center;
    padding:8px 12px; border-bottom:1px solid var(--green-dim);
    font-family:var(--font-display); font-size:15px; letter-spacing:.06em; color:var(--green-dim);
  }
  .titlebar .dot{ display:inline-block; width:7px; height:7px; border-radius:50%; background:var(--green-dim); margin-right:5px; }
  .titlebar .live .dot{ background:var(--green); box-shadow:0 0 6px var(--green); animation:pulse 1.4s infinite; }
  @keyframes pulse{ 0%,100%{opacity:1;} 50%{opacity:.3;} }
  .mute-btn{
    background:transparent; border:1px solid var(--green-dim); color:var(--green-dim);
    font-size:13px; line-height:1; padding:4px 7px; cursor:pointer;
    border-radius:2px; transition:color .15s, border-color .15s;
  }
  .mute-btn:hover{ color:var(--green); border-color:var(--green); }
  .mute-btn.muted{ color:var(--green-dim); opacity:.5; }

  .screen{ padding:16px 16px 18px; min-height:420px; display:flex; flex-direction:column; }

  /* ---------- stage / sprite ---------- */
  .stage{
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    min-height:180px; margin-bottom:10px; transition:opacity .25s;
  }
  .stage.hidden{ display:none; }
  .sprite-wrap{ animation:bob 1.8s ease-in-out infinite; }
  @keyframes bob{ 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-5px); } }
  .sprite-wrap.glitching{ animation:bob 1.8s ease-in-out infinite, glitchshift .12s steps(2) infinite; }
  @keyframes glitchshift{ 0%{ transform:translateX(0);} 50%{ transform:translateX(2px);} 100%{ transform:translateX(-2px);} }
  canvas#waveform{
    display:block; width:220px; height:84px;
    filter:drop-shadow(0 0 8px rgba(51,255,110,0.35));
  }
  .speaker-tag{
    margin-top:8px; font-family:var(--font-display); font-size:18px; letter-spacing:.08em;
    color:var(--green-bright); text-shadow:0 0 6px rgba(185,255,214,0.5);
  }
  .speaker-tag.warn{ color:var(--red); text-shadow:0 0 6px rgba(255,59,59,0.6); }

  /* ---------- system log line ---------- */
  .system-line{
    font-family:var(--font-display); font-size:19px; letter-spacing:.03em;
    color:var(--green-bright); text-align:center; padding:26px 6px;
    text-shadow:0 0 6px rgba(185,255,214,0.4);
  }
  .system-line.warn{ color:var(--red); text-shadow:0 0 8px rgba(255,59,59,0.6); }

  /* ---------- dialogue box ---------- */
  .dialogue-box{
    border:1px solid var(--green-dim);
    background:rgba(51,255,110,0.03);
    padding:12px 14px;
    font-size:14.5px; line-height:1.55; color:var(--green);
    min-height:96px;
  }
  .dialogue-box.hidden{ display:none; }

  /* ---------- feed panel ---------- */
  .feed-panel{
    border:1px dashed var(--green-dim);
    padding:10px 12px; font-size:12.5px; line-height:1.55;
    color:var(--green); max-height:280px; overflow-y:auto;
  }
  .feed-panel.hidden{ display:none; }
  .feed-header{ font-family:var(--font-display); font-size:16px; letter-spacing:.05em; color:var(--green-bright); margin-bottom:4px; }
  .feed-meta{ color:var(--green-dim); margin-bottom:8px; white-space:pre-line; }
  .feed-line{ margin:6px 0; }
  .feed-line .ts{ color:var(--green-dim); margin-right:6px; }
  .feed-jitter{ animation:jitter 3.2s infinite; }
  @keyframes jitter{ 0%,96%,100%{ transform:translateX(0);} 97%{ transform:translateX(-1px);} 98%{ transform:translateX(1px);} }

  /* ---------- hex panel ---------- */
  .hex-panel{ text-align:center; padding:10px 4px; }
  .hex-panel.hidden{ display:none; }
  .hex-header{ font-family:var(--font-display); font-size:16px; letter-spacing:.05em; color:var(--green-bright); margin-bottom:10px; }
  .hex-string{ font-size:14px; letter-spacing:.12em; color:var(--green-dim); margin-bottom:16px; word-break:break-all; }
  .decoded{ font-family:var(--font-display); font-size:30px; letter-spacing:.12em; color:var(--red); min-height:40px; text-shadow:0 0 10px rgba(255,59,59,0.6); }

  /* ---------- buttons ---------- */
  .btn{
    display:block; width:100%; background:transparent; border:1px solid var(--green);
    color:var(--green-bright); font-family:var(--font-display); font-size:18px; letter-spacing:.12em;
    padding:10px 14px; margin-top:14px; cursor:pointer; text-align:center; text-transform:uppercase;
    transition:background .15s, box-shadow .15s;
  }
  .btn:hover, .btn:focus-visible{ background:rgba(51,255,110,0.08); box-shadow:0 0 14px rgba(51,255,110,0.35); outline:none; }
  .btn:active{ background:rgba(51,255,110,0.18); }
  .btn.hidden{ display:none; }

  @media (prefers-reduced-motion: reduce){
    #crt::after, .titlebar .live .dot, .sprite-wrap, .sprite-wrap.glitching{ animation:none !important; }
  }
</style>
</head>
<body>

<canvas id="noise-canvas"></canvas>

<audio id="bgm" src="bgm_ambient.mp3" loop preload="auto"></audio>
<audio id="blip" src="dialogue_blip.mp3" preload="auto"></audio>

<div id="crt">
  <div class="terminal">
    <div class="titlebar">
      <span><span class="dot"></span>PROXY_NODE://04</span>
      <span style="display:flex;align-items:center;gap:12px;">
        <button id="muteBtn" class="mute-btn" aria-label="Toggle sound">🔊</button>
        <span class="live"><span class="dot"></span>LIVE</span>
      </span>
    </div>
    <div class="screen">

      <div class="stage hidden" id="stage">
        <div class="sprite-wrap" id="spriteWrap">
          <canvas id="waveform" width="220" height="84"></canvas>
        </div>
        <div class="speaker-tag" id="speakerTag"></div>
      </div>

      <div class="system-line hidden" id="systemLine"></div>

      <div class="feed-panel hidden" id="feedPanel">
        <div class="feed-header" id="feedHeader"></div>
        <div class="feed-meta" id="feedMeta"></div>
        <div id="feedLines"></div>
      </div>

      <div class="hex-panel hidden" id="hexPanel">
        <div class="hex-header">SYSTEM OVERLAY // HEX DATA BLOCK</div>
        <div class="hex-string" id="hexString"></div>
        <div class="decoded" id="decodedText"></div>
        <button class="btn" id="decodeBtn">Decode Block</button>
      </div>

      <div class="dialogue-box hidden" id="dialogueBox"><span id="dialogueText"></span></div>

      <button class="btn" id="continueBtn">Continue ▶</button>

    </div>
  </div>
</div>

<script>
(function(){
  "use strict";

  // =================================================================
  // Waveform / oscilloscope avatar — no face, just signal.
  // Bars pulse gently at idle, surge while the speaker is "talking."
  // Chase occasionally spikes red (signal corruption); Hiker stays a
  // dimmer, more erratic green (weak/degrading signal).
  // =================================================================
  const CHASE = { id:"chase", base:"#33ff6e", glitchColor:"#ff3b3b", glitchChance:0.05, jitter:0.12 };
  const HIKER = { id:"hiker", base:"#5fae82", glitchColor:null,      glitchChance:0,    jitter:0.22 };

  const waveCanvas = document.getElementById("waveform");
  const wctx = waveCanvas.getContext("2d");
  const BAR_COUNT = 26;
  const amps = new Array(BAR_COUNT).fill(0.04);

  let currentSpeaker = null;   // CHASE | HIKER | null
  let isActiveTalking = false;

  function startTalking(who){ currentSpeaker = who; isActiveTalking = true; }
  function stopTalking(who){ isActiveTalking = false; if(who) currentSpeaker = who; }

  function waveformLoop(){
    const w = waveCanvas.width, h = waveCanvas.height;
    wctx.clearRect(0, 0, w, h);

    const speaker = currentSpeaker;
    const barW = w / BAR_COUNT;
    const midY = h / 2;

    // baseline
    wctx.strokeStyle = "rgba(51,255,110,0.15)";
    wctx.beginPath();
    wctx.moveTo(0, midY);
    wctx.lineTo(w, midY);
    wctx.stroke();

    for(let i = 0; i < BAR_COUNT; i++){
      const active = isActiveTalking && speaker;
      const j = speaker ? speaker.jitter : 0.15;
      const target = active
        ? 0.25 + Math.random() * 0.75
        : 0.03 + Math.random() * j;
      amps[i] += (target - amps[i]) * 0.3;

      const barH = amps[i] * (h * 0.42);
      const x = i * barW + barW * 0.25;
      const bw = barW * 0.5;

      let color = speaker ? speaker.base : "#1f7a44";
      if(active && speaker && speaker.glitchColor && Math.random() < speaker.glitchChance){
        color = speaker.glitchColor;
      }
      wctx.fillStyle = color;
      wctx.shadowColor = color;
      wctx.shadowBlur = active ? 6 : 2;
      wctx.fillRect(x, midY - barH, bw, barH * 2);
    }
    wctx.shadowBlur = 0;
    requestAnimationFrame(waveformLoop);
  }
  requestAnimationFrame(waveformLoop);

  // =================================================================
  // Full-screen static wipe (transition flourish)
  // =================================================================
  const noiseCanvas = document.getElementById("noise-canvas");
  const nctx = noiseCanvas.getContext("2d");
  function resizeNoise(){ noiseCanvas.width = window.innerWidth; noiseCanvas.height = window.innerHeight; }
  resizeNoise();
  window.addEventListener("resize", resizeNoise);

  function playStatic(durationMs, cb){
    noiseCanvas.style.opacity = "0.9";
    const w = noiseCanvas.width, h = noiseCanvas.height;
    const imgData = nctx.createImageData(w, h);
    let frame = 0;
    const totalFrames = Math.round(durationMs / 40);
    function draw(){
      const buf = imgData.data;
      for(let i = 0; i < buf.length; i += 4){
        const v = Math.random() * 255;
        buf[i] = v * 0.2; buf[i+1] = v; buf[i+2] = v * 0.35; buf[i+3] = 255;
      }
      nctx.putImageData(imgData, 0, 0);
      frame++;
      if(frame < totalFrames){ requestAnimationFrame(draw); }
      else{ noiseCanvas.style.opacity = "0"; if(cb) cb(); }
    }
    draw();
  }

  // =================================================================
  // Audio — background loop (quiet) + per-character dialogue blip
  // =================================================================
  const bgmEl  = document.getElementById("bgm");
  const blipEl = document.getElementById("blip");
  const muteBtn = document.getElementById("muteBtn");

  const BGM_TARGET_VOLUME = 0.14; // kept low on purpose
  bgmEl.volume = 0;
  blipEl.volume = 0.55;

  let audioMuted = false;
  let audioUnlocked = false;

  function unlockAudio(){
    if(audioUnlocked) return;
    audioUnlocked = true;
    if(audioMuted) return;
    bgmEl.play().catch(() => {});
    let v = 0;
    const fade = setInterval(() => {
      v += 0.01;
      bgmEl.volume = Math.min(v, BGM_TARGET_VOLUME);
      if(v >= BGM_TARGET_VOLUME) clearInterval(fade);
    }, 60);
  }

  muteBtn.addEventListener("click", () => {
    audioMuted = !audioMuted;
    muteBtn.textContent = audioMuted ? "🔇" : "🔊";
    muteBtn.classList.toggle("muted", audioMuted);
    if(audioMuted){
      bgmEl.pause();
    }else if(audioUnlocked){
      bgmEl.play().catch(() => {});
    }else{
      unlockAudio();
    }
  });

  let blipCutTimer = null;
  function playBlip(){
    if(audioMuted) return;
    try{
      blipEl.currentTime = 0;
      blipEl.play().catch(() => {});
      clearTimeout(blipCutTimer);
      blipCutTimer = setTimeout(() => blipEl.pause(), 70);
    }catch(e){ /* ignore */ }
  }

  // =================================================================
  // Typewriter
  // =================================================================
  let typeTimer = null;
  let isTyping = false;
  function typeText(el, text, speed, onDone){
    clearTimeout(typeTimer);
    el.textContent = "";
    isTyping = true;
    let i = 0;
    function step(){
      if(i > text.length){
        isTyping = false;
        if(onDone) onDone();
        return;
      }
      el.textContent = text.slice(0, i);
      const ch = text[i - 1];
      if(ch && ch.trim() !== "") playBlip();
      i++;
      typeTimer = setTimeout(step, speed);
    }
    step();
  }
  function finishTyping(el, text, onDone){
    clearTimeout(typeTimer);
    el.textContent = text;
    isTyping = false;
    if(onDone) onDone();
  }

  // =================================================================
  // Script beats
  // =================================================================
  const beats = [
    { type:"system", text:"[SYSTEM_LOG]: Vector `168` verified. Static hum reduced by 100%." },

    { type:"chase", text:"Well, look at you. You actually forced the registry to clear. I didn't think your garbage setup had the processing power to filter out His background frequency. Honestly, I half-expected the terminal to just fry your hardware and spare me the chat. But a deal's a deal. You wanted a front-row seat to the show?" },
    { type:"chase", text:"Here. I just mirrored their uplink directly to your dashboard. Watch what happens when you ignore the 'Do Not Enter' signs and wander into a coordinate that doesn't exist anymore. Don't blink, sweetheart. The latency out there is a real killer." },

    { type:"feed",
      header:"LIVE UNLINK RECOVERY // FEED: HIKER_02_MARK",
      meta:"TIMESTAMP: ERR//ERR//ERR\nLOCATION: LAT [0.0000] // LONG [STATIC]",
      lines:[
        { t:"14:32", text:"mark if you find this phone just keep moving. jessica and i have been walking in a straight line for four hours but the landscape isn't changing. it's the same three pines over and over. copy paste. copy paste. the bark patterns are identical down to the millimeter. the forest is running out of unique variations." },
        { t:"14:41", text:"something is wrong with the audio delay. jessica tried to scream when she tripped over the roots but the sound didn't come out until three seconds later. the latency is getting worse. every time we breathe the fog tastes like copper and ozone. like hot plastic sitting on a motherboard." },
        { t:"14:55", text:"the map app isn't loading roads anymore. it's just a green grid stretching out forever. we tried to turn back but our tracks in the mud are already gone. not washed away. just gone. like they were never rendered." },
        { t:"15:03", text:"i can hear a keyboard clicking. it isn't coming from the phone. it's coming from right inside the fog behind us. every time i blink, the resolution of the trees drops. the edges are getting jagged and pixelated. he is rewriting the exit. he is waiting for the remainder to equal zero. jessica is gone. she didn't run away. she just stepped into a patch of dense fog and her signal dropped. i'm looking at my front camera right now. the little green recording light is on by itself. someone is watching us. someone is tracking the—" }
      ]
    },

    { type:"system", text:"[TERMINAL WARNING: HOST LAYER OVERRIDE]", warn:true },

    { type:"chase", text:"And... snap. The radar sweep just showed Hiker 01 and Hiker 02 coordinates successfully merging into a single static point. The hunt is officially concluded. Sucks to be them, honestly. They simply ran out of grid." },
    { type:"chase", text:"But hey, look on the bright side—the buzzing in the back of my head just stopped, which means 'He' is perfectly happy with the cleanup. And now that my dashboard is cleared up and the perimeter is nice and tidy... I notice I have a brand new open slot on my terminal tracker." },
    { type:"chase", text:"Let's see if your IP address is as easy to map as their hiking trail. Stay on the line, sweetheart. I'm calculating your vector next.", glitch:true },

    { type:"hex", hex:"54 48 45 20 46 4f 47 20 49 53 20 48 45 52 45", decoded:"THE FOG IS HERE" }
  ];

  // =================================================================
  // DOM refs
  // =================================================================
  const stageEl        = document.getElementById("stage");
  const spriteWrapEl   = document.getElementById("spriteWrap");
  const speakerTagEl   = document.getElementById("speakerTag");
  const systemLineEl   = document.getElementById("systemLine");
  const feedPanelEl    = document.getElementById("feedPanel");
  const feedHeaderEl   = document.getElementById("feedHeader");
  const feedMetaEl     = document.getElementById("feedMeta");
  const feedLinesEl    = document.getElementById("feedLines");
  const hexPanelEl     = document.getElementById("hexPanel");
  const hexStringEl    = document.getElementById("hexString");
  const decodedTextEl  = document.getElementById("decodedText");
  const decodeBtn      = document.getElementById("decodeBtn");
  const dialogueBoxEl  = document.getElementById("dialogueBox");
  const dialogueTextEl = document.getElementById("dialogueText");
  const continueBtn    = document.getElementById("continueBtn");

  function hideAllPanels(){
    stageEl.classList.add("hidden");
    systemLineEl.classList.add("hidden");
    feedPanelEl.classList.add("hidden");
    hexPanelEl.classList.add("hidden");
    dialogueBoxEl.classList.add("hidden");
    spriteWrapEl.classList.remove("glitching");
  }

  let idx = -1;
  let currentBeatDone = false; // becomes true once a beat is fully "settled" and continue should advance

  function render(){
    const beat = beats[idx];
    hideAllPanels();
    continueBtn.classList.remove("hidden");
    currentBeatDone = false;

    if(beat.type === "system"){
      systemLineEl.classList.remove("hidden");
      systemLineEl.classList.toggle("warn", !!beat.warn);
      typeText(systemLineEl, beat.text, 22, () => { currentBeatDone = true; });
      return;
    }

    if(beat.type === "chase"){
      stageEl.classList.remove("hidden");
      dialogueBoxEl.classList.remove("hidden");
      speakerTagEl.textContent = "@staticheadache404";
      speakerTagEl.classList.toggle("warn", !!beat.glitch);
      spriteWrapEl.classList.toggle("glitching", !!beat.glitch);
      startTalking(CHASE);
      typeText(dialogueTextEl, beat.text, 20, () => {
        stopTalking(CHASE);
        currentBeatDone = true;
      });
      return;
    }

    if(beat.type === "feed"){
      feedPanelEl.classList.remove("hidden");
      stageEl.classList.remove("hidden");
      speakerTagEl.textContent = "FEED: HIKER_02_MARK";
      speakerTagEl.classList.remove("warn");
      startTalking(HIKER);
      feedHeaderEl.textContent = "[ " + beat.header + " ]";
      feedMetaEl.textContent = beat.meta;
      feedLinesEl.innerHTML = "";
      feedPanelEl.classList.add("feed-jitter");

      let li = 0;
      function nextLine(){
        if(li >= beat.lines.length){
          stopTalking(HIKER);
          currentBeatDone = true;
          return;
        }
        const line = beat.lines[li];
        const div = document.createElement("div");
        div.className = "feed-line";
        const tsSpan = document.createElement("span");
        tsSpan.className = "ts";
        tsSpan.textContent = "(" + line.t + ")";
        const bodySpan = document.createElement("span");
        div.appendChild(tsSpan);
        div.appendChild(bodySpan);
        feedLinesEl.appendChild(div);
        feedPanelEl.scrollTop = feedPanelEl.scrollHeight;
        typeText(bodySpan, line.text, 12, () => {
          li++;
          feedPanelEl.scrollTop = feedPanelEl.scrollHeight;
          setTimeout(nextLine, 350);
        });
      }
      nextLine();
      return;
    }

    if(beat.type === "hex"){
      hexPanelEl.classList.remove("hidden");
      hexStringEl.textContent = beat.hex;
      decodedTextEl.textContent = "";
      continueBtn.classList.add("hidden");
      decodeBtn.classList.remove("hidden");
      decodeBtn.onclick = function(){
        unlockAudio();
        decodeBtn.classList.add("hidden");
        playStatic(500, () => {
          const target = beat.decoded;
          let i = 0;
          const glitchChars = "!<>-_\\/[]{}—=+*^?#";
          const timer = setInterval(() => {
            if(i > target.length){
              clearInterval(timer);
              decodedTextEl.textContent = target;
              currentBeatDone = true;
              return;
            }
            let out = target.slice(0, i);
            for(let k = i; k < target.length; k++){
              out += target[k] === " " ? " " : glitchChars[Math.floor(Math.random() * glitchChars.length)];
            }
            decodedTextEl.textContent = out;
            i++;
          }, 60);
        });
      };
      return;
    }
  }

  function advance(){
    if(isTyping){
      // fast-forward current line instead of advancing
      if(beats[idx].type === "system") finishTyping(systemLineEl, beats[idx].text, () => currentBeatDone = true);
      else if(beats[idx].type === "chase"){ stopTalking(CHASE); finishTyping(dialogueTextEl, beats[idx].text, () => currentBeatDone = true); }
      return;
    }
    if(idx >= 0 && !currentBeatDone) return; // still animating (e.g. feed lines)

    idx++;
    if(idx >= beats.length) return;

    const transitionBeats = ["feed", "hex"];
    if(idx > 0 && transitionBeats.includes(beats[idx].type)){
      playStatic(450, render);
    }else{
      render();
    }
  }

  continueBtn.addEventListener("click", () => { unlockAudio(); advance(); });

  // kick off
  advance();

})();
</script>
</body>
</html>
